# CoinSwitch API Credentials
# Get these from your CoinSwitch PRO dashboard
COINSWITCH_API_KEY=your_api_key_here
COINSWITCH_SECRET_KEY=your_hex_secret_here

# Optional: Slack webhook alerts
# Leave these unset if you do not want Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_ALERTS_ENABLED=true
# SLACK_OPPORTUNITY_ALERTS_ENABLED=true
# SLACK_EXECUTION_ALERTS_ENABLED=true
# SLACK_ALERT_COOLDOWN_SECONDS=60
# SLACK_ALERT_USERNAME=OmniArb

# Optional: Server configuration
# PORT=8080
