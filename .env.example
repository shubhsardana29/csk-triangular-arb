# CoinSwitch API Credentials
# Get these from your CoinSwitch PRO dashboard
COINSWITCH_API_KEY=your_api_key_here
COINSWITCH_SECRET_KEY=your_hex_secret_here

# Optional: Slack webhook alerts
# Leave these unset if you do not want Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_ALERTS_ENABLED=true
# SLACK_OPPORTUNITY_ALERTS_ENABLED=true
# SLACK_EXECUTION_ALERTS_ENABLED=true
# SLACK_ALERT_COOLDOWN_SECONDS=60
# SLACK_ALERT_USERNAME=OmniArb

# Optional: n8n webhook integration
# N8N_WEBHOOK_ENABLED=false
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/arb-opportunity

# Optional: Control API (allows n8n to change strategy params at runtime)
# Binds to localhost only — never exposed to the network.
# CONTROL_API_ENABLED=false
# CONTROL_API_HOST=127.0.0.1
# CONTROL_API_PORT=8765
# CONTROL_API_SECRET=change-me-to-a-random-string
